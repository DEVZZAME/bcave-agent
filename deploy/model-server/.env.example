# ── vLLM 모델 서버 환경변수 ──

# GPU VRAM 프로파일: 48gb (기본) | 24gb | 80gb
VRAM_PROFILE=48gb

# 서버 API 키 (게이트웨이 → 모델서버 인증용). 반드시 변경할 것.
MODEL_SERVER_KEY=change-me-in-production

# 모델 서버 수신 포트 (기본 8000)
MODEL_SERVER_PORT=8000

# HuggingFace 토큰 (비공개 가중치 접근 필요 시)
HF_TOKEN=

# HuggingFace 캐시 디렉토리
HF_CACHE_DIR=~/.cache/huggingface
